{
  "name": "aether-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Aether AI - Agentic AI Chatbot SaaS Monorepo",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --recursive build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6",
    "next": "14.2.5"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "protobufjs",
      "sharp",
      "@xenova/transformers",
      "onnxruntime-node",
      "pdf-parse",
      "mammoth"
    ]
  }
